        "import numpy as np\n",
        "A = np.array([[2, 3],\n",
        "              [1, 2]])\n",
        "b = np.array([5, 3])\n",
        "x = np.linalg.solve(A, b)\n",
        "print(\"Matrix A:\")\n",
        "print(A)\n",
        "print(\"\\nVector b:\")\n",
        "print(b)\n",
        "print(\"\\nSolution vector x:\")\n",
        "print(x)"
